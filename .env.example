# =============================================================
# CodeRIT Website — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to version control.
# =============================================================


# ── MongoDB ───────────────────────────────────────────────────
# Your MongoDB connection string (Atlas or local).
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority


# ── Cloudinary (image uploads) ────────────────────────────────
# Used by /api/addimage — find these in your Cloudinary dashboard.
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret
